<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
<addon id="repository.adamsbuilds" name="adamsbuilds" version="1.0" provider-name="adamsbuilds">
    <extension point="xbmc.addon.repository" name="adamsbuilds repository">
        <dir>
            <info compressed="false">https://raw.githubusercontent.com/adamsbuilds/repo/master/zips/addons.xml</info>
            <checksum>https://raw.githubusercontent.com/adamsbuilds/repo/master/zips/addons.md5</checksum>
            <datadir zip="true">https://raw.githubusercontent.com/adamsbuilds/repo/master/zips/</datadir>
        </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary>adamsbuilds</summary>
        <description>adamsbuilds repository</description>
        <disclaimer></disclaimer>
		<source>https://adamsbuilds.github.io/repo/</source>
        <platform>all</platform>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
    </extension>
</addon>
<addon id="plugin.program.valarswizard" name="ValarsWizard" version="1.8" provider-name="Slam, Sarge, Funsterbe, BYB, adamsbuilds">
	<requires>
		<import addon="xbmc.python" version="3.0.0"/>
	</requires>
	<extension point="xbmc.python.pluginsource" library="addon.py">
		<provides>executable</provides>
	</extension>
	<extension point="xbmc.service" library="service.py" />
	<extension point="xbmc.addon.metadata">
		<summary lang="en_GB">ValarsWizard is a tool for backup/restore and maintenance of Kodi builds.  Forked from simplewizard.</summary>
		<description lang="en_GB">Kodi Wizard</description>
		<disclaimer lang="en_GB">This Addon contains no content.  Creator assumes no responsibily for content obtained by 3rd party addons. Use at your own risk!</disclaimer>
		<language>en</language>
		<platform>all</platform>
		<license>GPL-2.0-or-later</license>
		<forum></forum>
		<website></website> 
		<email></email>
		<source><source>https://adamsbuilds.github.io/repo/</source></source>
		<news></news>
		<assets>
				<icon>resources/icon.png</icon>
				<fanart>resources/fanart.jpg</fanart>
				<banner></banner>
				<clearlogo></clearlogo>
				<screenshot></screenshot>
		</assets>
	</extension>
</addon>
<addon id="context.trailer" name="Play Trailer" version="1.0" provider-name="BigNoid, adamsbuilds">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>
  <extension point="kodi.context.item">
    <menu id="kodi.core.main">
      <item library="addon.py">
        <label>32000</label>
        <visible>[String.IsEqual(ListItem.dbtype,movie) | String.IsEqual(ListItem.dbtype,tvshow) | String.IsEqual(ListItem.dbtype,season) | String.IsEqual(ListItem.dbtype,episode)] + !String.IsEmpty(ListItem.Trailer)</visible>
      </item>
    </menu>
  </extension>
  <extension point="kodi.addon.metadata">
    <platform>all</platform>
    <summary lang="en">Play a movie trailer from the context menu in the library.</summary>
    <description lang="en">Adds a context menu entry for movies that have a trailer in the database. Choose windowed or fullscreen play in the settings.</description>
    <license>GNU GENERAL PUBLIC LICENSE. Version 3, 29 June 2007</license>
    <forum></forum>
    <source>https://github.com/BigNoid/context.trailer</source>
  </extension>
</addon>
